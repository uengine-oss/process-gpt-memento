SUPABASE_URL=
SUPABASE_KEY=

# openai | openrouter | custom
MEMENTO_LLM_PROVIDER=openai
MEMENTO_EMBEDDING_PROVIDER=openai

OPENAI_API_KEY=
OPENROUTER_API_KEY=
CUSTOM_LLM_API_KEY=
CUSTOM_EMBEDDING_API_KEY=

# custom provider only
CUSTOM_LLM_BASE_URL=
CUSTOM_EMBEDDING_BASE_URL=

MEMENTO_TRACEMALLOC=0

# PDF 이미지 추출 + 비전 분석 on/off (true|false).
MEMENTO_IMAGE_ANALYSIS=

# --- 폐쇄망 파서 (Synap DocuAnalyzer, 선택) ---
# 외부 회사 내부망에서 자체 제공하는 DocuAnalyzer 엔진을 사용할 때만 활성화.
# true 로 바꾸면 hwp/hwpx/pdf/docx/pptx/xlsx 등을 로컬 파서 대신 원격 API로 파싱한다.
SYNAP_ENABLED=false
SYNAP_API_KEY=
SYNAP_URL=
